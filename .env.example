SPRING_ENV=dev
SPRING_APP_NAME=AppointmensMicroservice
SPRING_LOG_LEVEL=WARN

SPRING_JWT_SECRET=secret-key
SPRING_JWT_PUBLIC=/**,/api/v1/health,/v3/api-docs/**,/swagger-ui/**
SPRING_JWT_ISSUER=login-service

HOST_PORT=8082
HOST_DB_PORT=3306

MYSQL_DATABASE=appointments
MYSQL_HOST=localhost
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=user

DOCKER_DOMAIN_NETWORK=fullstack_network
PHPMYADMIN_PORT=8088
